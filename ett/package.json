{
  "name": "ett-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:web": "vite",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/src/server.js",
    "lint": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "import:tnved": "tsx scripts/import-tnved.ts",
    "import:duty": "tsx scripts/import-duty.ts",
    "import:honest": "tsx scripts/import-honest-sign.ts"
  },
  "dependencies": {
    "@fastify/multipart": "^9.2.1",
    "@fastify/static": "^8.2.0",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.4.0",
    "mysql2": "^3.15.0",
    "pdfkit": "^0.17.1",
    "pino": "^9.9.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/pdfkit": "^0.17.3",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^6.3.5"
  }
}

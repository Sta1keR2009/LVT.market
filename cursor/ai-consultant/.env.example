HOST=127.0.0.1
PORT=3847

# --- LLM: переключение провайдера (openai | deepseek | qwen) ---
LLM_PROVIDER=openai

# OpenAI (LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Необязательно: свой прокси / Azure OpenAI
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek — OpenAI-совместимый API (LLM_PROVIDER=deepseek)
# Ключ: DEEPSEEK_API_KEY или тот же OPENAI_API_KEY
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Qwen (Alibaba DashScope) — compatible-mode OpenAI API (LLM_PROVIDER=qwen)
# Ключ: QWEN_API_KEY или DASHSCOPE_API_KEY или OPENAI_API_KEY
# QWEN_API_KEY=
# Международный эндпоинт по умолчанию; для материкового КНР см. документацию DashScope
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus

PUBLIC_ORIGIN=https://lvt.market,https://www.lvt.market
BITRIX_BASE_URL=https://lvt.market

# Optional: own catalog HTTP API for stock/specs (otherwise agent guides to site / manager)
CATALOG_API_URL=
ANALOGS_API_URL=

# POST JSON with session_id, channel, reason, summary — notify sales team
HANDOFF_WEBHOOK_URL=

TELEGRAM_BOT_TOKEN=
# Прокси для api.telegram.org (РФ): socks5 или http
# TELEGRAM_PROXY_URL=socks5://USER:PASS@HOST:PORT
# TELEGRAM_PROXY_TYPE=socks5
# TELEGRAM_PROXY_HOST=
# TELEGRAM_PROXY_PORT=
# TELEGRAM_PROXY_USER=
# TELEGRAM_PROXY_PASS=
# Встроенный webhook в оркестраторе (smoke-test). Для продакшена с telegrambot/ держите 0.
# ENABLE_TELEGRAM_WEBHOOK=0
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

INTERNAL_ANALYTICS_KEY=

# Виджет ↔ Telegram / веб-панель менеджера
# WIDGET_BRIDGE_INTERNAL_KEY=
# TELEGRAM_MANAGERS_CHAT_ID=
# TELEGRAM_BOT_TOKEN=
# MANAGER_PANEL_BASE_URL=https://lvt.market/local/api/ai_manager_chat.php
# MANAGER_PANEL_SECRET=  # по умолчанию = WIDGET_BRIDGE_INTERNAL_KEY
# MANAGER_TOKEN_TTL_SEC=604800

# Системный промпт (путь от каталога ai-consultant)
AGENT_SYSTEM_PROMPT_PATH=prompts/agent_system.ru.md
# AGENT_PROMPT_HOT_RELOAD=1

# Заявки с сайта → Telegram (PHP local/api/ai_consultant_lead.php)
# TELEGRAM_LEAD_BOT_TOKEN=
# TELEGRAM_LEAD_CHAT_ID=

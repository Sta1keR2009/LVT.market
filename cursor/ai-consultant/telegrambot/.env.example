# Токен бота (@BotFather) — тот же, что для консультанта
TELEGRAM_BOT_TOKEN=

# Прокси для api.telegram.org (обязательно при блокировке в РФ). Для Node — http://
# TELEGRAM_PROXY_URL=http://USER:PASS@153.80.171.52:64504
# SOCKS5 (64505) — для PHP curl; в Node используйте http-прокси (64504)

# Оркестратор ai-consultant (только localhost)
AI_BACKEND_URL=http://127.0.0.1:3847

# Заявка менеджеру (публичный PHP на сайте)
LEAD_API_URL=https://lvt.market/local/api/ai_consultant_lead.php

# Чат менеджеров (t.me/c/3685309637 → -1003685309637)
TELEGRAM_MANAGERS_CHAT_ID=-1003685309637
TELEGRAM_MANAGER_USER_IDS=399334751

# Яндекс Вебмастер (команда /webmaster и кнопка для TELEGRAM_MANAGER_USER_IDS)
# Тот же OAuth, что в site-monitor: /etc/lvt/site-monitor.env
YANDEX_WEBMASTER_OAUTH_TOKEN=
YANDEX_WEBMASTER_DOMAINS=lvt.market,lvtgroup.ru

# Long polling (по умолчанию). Для webhook задайте TELEGRAM_USE_WEBHOOK=1 и TELEGRAM_WEBHOOK_PORT
# TELEGRAM_USE_WEBHOOK=0
# TELEGRAM_WEBHOOK_PORT=3848
# TELEGRAM_WEBHOOK_PATH=/telegram-webhook

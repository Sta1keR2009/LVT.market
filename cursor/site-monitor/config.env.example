# Скопируйте в /etc/lvt/site-monitor.env и задайте значения.
# Можно использовать отдельного бота для алертов (рекомендуется) или существующий.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Прокси для api.telegram.org (как у ai-consultant), если нужен:
# TELEGRAM_PROXY_URL=http://user:pass@host:port

# Окно анализа логов (часы)
LOOKBACK_HOURS=24

# Пороги
DISK_WARN_PCT=85
DISK_CRIT_PCT=92
SWAP_WARN_MB=1024
LOAD_WARN=12
MYSQL_CONN_WARN=250
SSL_WARN_DAYS=14
SLOW_PHP_WARN=50

# Проверки HTTP (через запятую)
HEALTH_URLS=https://lvt.market/,https://lvtgroup.ru/,http://127.0.0.1:3847/health

# Мгновенные алерты (cron */15, режим --alert)
ALERT_LOOKBACK_HOURS=1
ALERT_COOLDOWN_MINUTES=60
ALERT_COUNT_DELTA=5
ALERT_MIN_COUNT=3
# ALERT_STATE_PATH=/var/lib/lvt-site-monitor/alert-state.json

# Яндекс Вебмастер API (OAuth): https://oauth.yandex.ru/
# Права приложения: webmaster:read (или полный доступ к Вебмастеру)
YANDEX_WEBMASTER_OAUTH_TOKEN=

# Домены для отчёта (через запятую; должны быть добавлены в Вебмастере)
YANDEX_WEBMASTER_DOMAINS=lvt.market,lvtgroup.ru
